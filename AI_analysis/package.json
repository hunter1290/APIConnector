{
  "name": "ai-analysis",
  "version": "0.1.0",
  "description": "Stateless microservice that calls a configured AI provider (Anthropic/OpenAI) to analyze data on behalf of the APIConnector backend.",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "express": "^4.19.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.19.43",
    "tsx": "^4.16.2",
    "typescript": "^5.9.3"
  }
}
