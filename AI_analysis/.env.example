# Copy this file to .env and fill in real values. Never commit the real .env (already
# gitignored). APIConnector supplies these credentials — end users never enter their own key.

PORT=4000

# Must match the Java backend's app.ai.analysis.shared-secret / AI_ANALYSIS_SHARED_SECRET.
# Override this in every real environment.
INTERNAL_SHARED_SECRET=dev-only-shared-secret-change-me

# Timeout (ms) for the outbound call to the AI provider.
REQUEST_TIMEOUT_MS=20000

# One key per provider. A provider with no key here just fails its /analyze calls with a
# clear "not configured" error — the service still starts fine without any of these set.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
